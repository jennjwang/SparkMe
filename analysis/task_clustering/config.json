{
  "input": {
    "path": "analysis/task_clustering/output/screened_study_tasks.json",
    "text_field": "task_statement",
    "source_field": "occupation",
    "timestamp_field": null,
    "items_field": "tasks"
  },

  "output": {
    "state": "analysis/task_clustering/output/clusters.json",
