  },

  "taxonomy": null,
  "criteria": null,
  "resume": null,

  "algorithm": {
    "model": "gpt-5.4",
    "lambda": 0.1,
    "eps": 0.5,
    "max_split_size": 10,
    "split_depth_limit": 1,
    "fade_interval_interviews": 4,
    "no_splits": false
  }
